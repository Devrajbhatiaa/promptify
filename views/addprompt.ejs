<%- include('head') %>
<%- include('nav') %>
<style>
.create-page { padding: 40px 0 80px; position: relative; z-index: 1; }
.create-header { margin-bottom: 26px; }
.create-header h1 { font-size: 32px; font-weight: 800; margin-bottom: 8px; }
.create-header p { color: var(--t2); }
.form-shell { max-width: 820px; background: var(--s1); border: 1px solid var(--border); border-radius: var(--rl); padding: 26px; }
.form-grid { display: grid; gap: 16px; }
.f-label { display: block; margin-bottom: 8px; color: var(--t2); font-size: 13px; font-weight: 600; }
.f-input, .f-textarea, .f-select { width: 100%; border: 1px solid var(--border); background: var(--s2); color: var(--text); border-radius: var(--r); padding: 12px 14px; font-size: 14px; }
.f-textarea { min-height: 180px; resize: vertical; }
.f-input:focus, .f-textarea:focus, .f-select:focus { outline: none; border-color: var(--accent); }
.action-row { display: flex; gap: 10px; margin-top: 10px; flex-wrap: wrap; }
</style>

<div class="page-wrap">
  <div class="container create-page">
    <div class="create-header slide-up">
      <h1>Create Prompt</h1>
      <p>Share your best prompt with the community.</p>
    </div>

    <div class="form-shell slide-up stagger-1">
      <form action="/post" method="POST" class="form-grid">
        <div>
          <label class="f-label" for="title">Title</label>
          <input class="f-input" type="text" id="title" name="title" required placeholder="A short, clear title" maxlength="120">
        </div>
        <div>
          <label class="f-label" for="content">Prompt</label>
          <textarea class="f-textarea" id="content" name="content" required placeholder="Write your prompt..."></textarea>
        </div>
        <div>
          <label class="f-label" for="category">Category</label>
          <select class="f-select" id="category" name="category">
            <option value="general">General</option>
            <option value="writing">Writing</option>
            <option value="coding">Coding</option>
            <option value="design">Design</option>
            <option value="marketing">Marketing</option>
            <option value="education">Education</option>
          </select>
        </div>
        <div>
          <label class="f-label" for="communityId">Post to Community (Optional)</label>
          <select class="f-select" id="communityId" name="communityId">
            <option value="">Public Post (Trending)</option>
            <% (myCommunities || []).forEach(function(c) { %>
              <option value="<%= c._id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="action-row">
          <a href="/home" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary">Create Prompt</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/main.js"></script>
</body></html>
