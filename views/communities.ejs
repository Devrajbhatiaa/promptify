<%- include('head') %>
<style>
.comm-page { padding: 40px 0 80px; position: relative; z-index: 1; }
.comm-hero { text-align: center; margin-bottom: 48px; }
.comm-hero h1 { font-size: 36px; font-weight: 800; margin-bottom: 12px; }
.comm-hero p { color: var(--t2); font-size: 16px; max-width: 500px; margin: 0 auto 24px; }
.create-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--accent); color: white; border-radius: var(--r); font-weight: 600; text-decoration: none; transition: all var(--tr); }
.create-btn:hover { background: var(--accent-h); transform: translateY(-2px); }
.communities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
.comm-card { background: var(--s1); border: 1px solid var(--border); border-radius: var(--rl); padding: 24px; transition: all var(--tr); }
.comm-card:hover { border-color: var(--border-h); transform: translateY(-3px); }
.comm-card-header { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
.comm-icon { width: 48px; height: 48px; border-radius: var(--r); background: linear-gradient(135deg, var(--accent), var(--accent-h)); display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; color: white; }
.comm-card-title { font-size: 18px; font-weight: 700; }
.comm-card-desc { color: var(--t2); font-size: 14px; margin-bottom: 16px; line-height: 1.6; }
.comm-card-meta { display: flex; gap: 16px; font-size: 13px; color: var(--t3); }
.comm-card-meta span { display: flex; align-items: center; gap: 5px; }
.comm-card-footer { display: flex; gap: 10px; margin-top: 16px; }
.empty-state { text-align: center; padding: 60px 20px; }
.empty-state svg { width: 64px; height: 64px; color: var(--t3); margin-bottom: 16px; }
</style>

<div class="page-wrap">
  <div class="comm-page container">
    <div class="comm-hero slide-up">
      <h1>Communities</h1>
      <p>Join communities of prompt creators, share ideas, and collaborate with like-minded people.</p>
      <% if (user) { %>
        <a href="/community/create" class="create-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Create Community
        </a>
      <% } %>
    </div>

    <% if (communities.length === 0) { %>
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        <h3>No communities yet</h3>
        <p>Be the first to create a community!</p>
        <% if (user) { %>
          <a href="/community/create" class="btn btn-primary" style="margin-top:16px;">Create Community</a>
        <% } %>
      </div>
    <% } else { %>
      <div class="communities-grid">
        <% communities.forEach(function(community) { %>
          <div class="comm-card slide-up">
            <div class="comm-card-header">
              <div class="comm-icon"><%= community.name.charAt(0).toUpperCase() %></div>
              <div class="comm-card-title"><%= community.name %></div>
            </div>
            <% if (community.description) { %>
              <p class="comm-card-desc"><%= community.description.substring(0, 100) %><%= community.description.length > 100 ? '...' : '' %></p>
            <% } %>
            <div class="comm-card-meta">
              <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <%= community.memberCount %> members
              </span>
              <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <%= community.prompts?.length || 0 %> prompts
              </span>
            </div>
             <div class="comm-card-footer">
               <a href="/community/<%= community._id %>" class="btn btn-primary btn-sm">View</a>
               <% if (user) { %>
                 <% if (userCommunityIds && userCommunityIds.includes(community._id.toString())) { %>
                   <span class="btn btn-ghost btn-sm joined-badge">Joined</span>
                <% } else { %>
                   <form action="/community/<%= community._id %>/join" method="POST" style="display:inline;">
                     <button type="submit" class="btn btn-ghost btn-sm">Join</button>
                   </form>
                 <% } %>
               <% } %>
             </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<script src="/main.js"></script>
</body></html>