<%- include('head') %>
<style>
.landing-shell {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: radial-gradient(circle at 15% 20%, rgba(124, 92, 239, 0.18), transparent 35%),
    radial-gradient(circle at 85% 82%, rgba(180, 80, 200, 0.14), transparent 35%),
    linear-gradient(140deg, #05050b 0%, #10071e 52%, #05050b 100%);
  background-size: 130% 130%;
  animation: shellShift 16s ease-in-out infinite;
}
[data-theme="light"] .landing-shell {
  background: radial-gradient(circle at 15% 20%, rgba(79, 70, 229, 0.14), transparent 35%),
    radial-gradient(circle at 85% 82%, rgba(147, 51, 234, 0.1), transparent 35%),
    linear-gradient(140deg, #eef2ff 0%, #f8fafc 52%, #eef2ff 100%);
}
@keyframes shellShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
.landing-shell::before,
.landing-shell::after {
  content: "";
  position: absolute;
  border-radius: 999px;
  filter: blur(68px);
  pointer-events: none;
  z-index: 0;
}
.landing-shell::before {
  width: 380px;
  height: 380px;
  left: -80px;
  top: 18%;
  background: rgba(124, 92, 239, 0.25);
  animation: blobDriftA 12s ease-in-out infinite alternate;
}
.landing-shell::after {
  width: 320px;
  height: 320px;
  right: -70px;
  bottom: 8%;
  background: rgba(244, 114, 182, 0.2);
  animation: blobDriftB 14s ease-in-out infinite alternate;
}
@keyframes blobDriftA {
  0% { transform: translate(0, 0) scale(0.95); }
  100% { transform: translate(46px, -34px) scale(1.1); }
}
@keyframes blobDriftB {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(-52px, 40px) scale(1.12); }
}
.landing-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}
.landing-particles span {
  position: absolute;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: rgba(167, 139, 250, 0.6);
  animation: particleFloat 6s ease-in-out infinite;
}
.landing-particles span:nth-child(odd) {
  background: rgba(196, 181, 253, 0.45);
  animation-duration: 7.5s;
}
.landing-particles span:nth-child(3n) {
  width: 4px;
  height: 4px;
  background: rgba(103, 232, 249, 0.45);
}
@keyframes particleFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.25; }
  50% { transform: translateY(-28px) scale(1.35); opacity: 0.95; }
}
.landing {
  min-height: 100vh;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 96px 20px 56px;
}
.landing-title {
  font-size: clamp(52px, 10vw, 108px);
  font-weight: 800;
  line-height: 0.96;
  letter-spacing: -3px;
  margin-bottom: 20px;
  background: linear-gradient(120deg, #d8b4fe 10%, #a78bfa 45%, #f0abfc 70%, #67e8f9 100%);
  background-size: 220% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: titleWave 8s linear infinite;
}
[data-theme="light"] .landing-title {
  background: linear-gradient(120deg, #4f46e5 10%, #7c3aed 45%, #9333ea 70%, #0f172a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
@keyframes titleWave {
  0% { background-position: 0% 50%; }
  100% { background-position: 200% 50%; }
}
.landing-sub {
  max-width: 700px;
  font-size: 18px;
  color: var(--t2);
  line-height: 1.75;
  margin-bottom: 36px;
}
.landing-ctas {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
  margin-bottom: 34px;
}
.btn-glow {
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 28px rgba(124, 92, 239, 0.34);
  isolation: isolate;
}
.btn-glow::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.26) 50%, transparent 100%);
  transform: translateX(-120%);
  animation: ctaShimmer 2.2s ease-in-out infinite;
}
.btn-glow::before {
  content: "";
  position: absolute;
  inset: -3px;
  border-radius: inherit;
  background: conic-gradient(from 0deg, rgba(167, 139, 250, 0.35), rgba(103, 232, 249, 0.28), rgba(244, 114, 182, 0.32), rgba(167, 139, 250, 0.35));
  z-index: -1;
  animation: ringSpin 4.2s linear infinite;
}
@keyframes ctaShimmer {
  0% { transform: translateX(-120%); }
  65%, 100% { transform: translateX(130%); }
}
@keyframes ringSpin {
  to { transform: rotate(360deg); }
}
.landing-features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 26px;
  margin-bottom: 70px;
}
.feat-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #c4b5fd;
  font-size: 13px;
  font-weight: 500;
  transition: transform var(--tr), color var(--tr), text-shadow var(--tr);
}
[data-theme="light"] .feat-pill { color: #5b21b6; }
.feat-pill svg { opacity: 0.9; }
.feat-pill:hover {
  transform: translateY(-2px);
  color: #ddd6fe;
  text-shadow: 0 0 20px rgba(167, 139, 250, 0.4);
}
[data-theme="light"] .feat-pill:hover { color: #4338ca; }
.landing-cards {
  width: min(980px, 100%);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}
.lcard {
  background: rgba(17, 24, 39, 0.62);
  border: 1px solid rgba(167, 139, 250, 0.22);
  border-radius: var(--rl);
  backdrop-filter: blur(8px);
  padding: 25px;
  text-align: left;
  transition: transform var(--tr), border-color var(--tr), box-shadow var(--tr), background var(--tr);
  position: relative;
  overflow: hidden;
}
[data-theme="light"] .lcard {
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(79, 70, 229, 0.22);
}
.lcard:hover {
  transform: translateY(-4px);
  border-color: rgba(167, 139, 250, 0.52);
  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
}
.lcard::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 20%, rgba(255,255,255,0.08) 50%, transparent 80%);
  transform: translateX(-130%);
  transition: transform 480ms ease;
}
.lcard:hover::after { transform: translateX(130%); }
.lcard-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
  transition: transform var(--tr), box-shadow var(--tr);
}
.lcard-icon-accent { background: rgba(124, 92, 239, 0.16); color: #a78bfa; }
.lcard-icon-green { background: rgba(45, 212, 191, 0.12); color: #14b8a6; }
.lcard-icon-amber { background: rgba(251, 191, 36, 0.14); color: #f59e0b; }
.lcard h3 { font-size: 17px; margin-bottom: 8px; }
.lcard p { font-size: 13px; color: var(--t2); line-height: 1.7; }
.lcard:hover .lcard-icon {
  transform: translateY(-2px) scale(1.06);
  box-shadow: 0 10px 24px rgba(124, 92, 239, 0.28);
}
.pub-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 120;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 64px;
  padding: 0 34px;
  background: rgba(5, 5, 11, 0.42);
  border-bottom: 1px solid rgba(167, 139, 250, 0.16);
  backdrop-filter: blur(12px);
}
[data-theme="light"] .pub-nav {
  background: rgba(248, 250, 252, 0.88);
  border-bottom: 1px solid rgba(79, 70, 229, 0.14);
}
.pub-nav-logo {
  color: var(--text);
  font-weight: 800;
  letter-spacing: 3px;
  font-size: 17px;
}
.pub-nav-logo span { color: #a78bfa; }
[data-theme="light"] .pub-nav-logo span { color: #4f46e5; }
.pub-nav-links { display: flex; gap: 8px; }

@media (max-width: 900px) {
  .landing-cards { grid-template-columns: 1fr; max-width: 560px; }
}
@media (max-width: 768px) {
  .landing { padding-top: 104px; }
  .pub-nav { padding: 0 16px; }
  .landing-title { letter-spacing: -2px; }
}
@media (prefers-reduced-motion: reduce) {
  .landing-shell,
  .landing-shell::before,
  .landing-shell::after,
  .landing-title,
  .landing-particles span,
  .btn-glow::before,
  .btn-glow::after {
    animation: none !important;
  }
}
</style>

<div class="landing-shell">
  <div class="landing-particles" aria-hidden="true">
    <span style="left:10%;top:20%;animation-delay:0s"></span>
    <span style="left:22%;top:72%;animation-delay:1.2s"></span>
    <span style="left:34%;top:40%;animation-delay:2.4s"></span>
    <span style="left:44%;top:16%;animation-delay:1.6s"></span>
    <span style="left:55%;top:68%;animation-delay:0.8s"></span>
    <span style="left:66%;top:34%;animation-delay:2.2s"></span>
    <span style="left:78%;top:76%;animation-delay:0.4s"></span>
    <span style="left:88%;top:28%;animation-delay:1.8s"></span>
    <span style="left:14%;top:54%;animation-delay:2.8s"></span>
    <span style="left:72%;top:12%;animation-delay:1s"></span>
  </div>
  <nav class="pub-nav">
    <a class="pub-nav-logo">PROMPT<span>IFY</span></a>
    <div class="pub-nav-links">
      <button class="theme-toggle btn btn-ghost btn-sm" id="theme-toggle" type="button" aria-label="Toggle theme">
        <span class="theme-icon" aria-hidden="true">🌙</span>
        <span class="theme-label">Dark</span>
      </button>
      <a href="/login" class="btn btn-ghost btn-sm">Sign In</a>
      <a href="/signin" class="btn btn-primary btn-sm">Get Started</a>
    </div>
  </nav>

  <div class="landing">
    <h1 class="landing-title slide-up stagger-1">Prompt Generator</h1>

    <p class="landing-sub slide-up stagger-2">
      Elevate your AI interactions with premium prompt crafting, lightning-fast generation, and community-powered inspiration.
    </p>

    <div class="landing-ctas slide-up stagger-3">
      <a href="/signin" class="btn btn-primary btn-lg btn-glow">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Get Started
      </a>
      <a href="/trending" class="btn btn-ghost btn-lg">Explore Trending</a>
    </div>

    <div class="landing-features slide-up stagger-4">
      <div class="feat-pill"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l2.8 5.7 6.2.9-4.5 4.4 1.1 6.2L12 17.4l-5.6 2.8 1.1-6.2L3 9.6l6.2-.9L12 3z"/></svg>AI-Powered Enhancement</div>
      <div class="feat-pill"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Instant Generation</div>
      <a href="/trending" class="feat-pill"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>Trending Templates</a>
    </div>

    <div class="landing-cards">
      <div class="lcard slide-up stagger-2">
        <div class="lcard-icon lcard-icon-accent">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3>AI Enhancement</h3>
        <p>Turn simple ideas into rich, production-ready prompts using fast AI-assisted prompt expansion.</p>
      </div>
      <div class="lcard slide-up stagger-3">
        <div class="lcard-icon lcard-icon-green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
        </div>
        <h3>Save & Organize</h3>
        <p>Create your personal prompt library and keep your best ideas ready for any model or workflow.</p>
      </div>
      <div class="lcard slide-up stagger-4">
        <div class="lcard-icon lcard-icon-amber">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <h3>Community Likes</h3>
        <p>Discover top prompts from creators, save favorites, and learn what performs best in real time.</p>
      </div>
    </div>
  </div>
</div>

<script src="/main.js"></script>
</body>
</html>
