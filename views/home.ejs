<%- include('head') %>
<%- include('nav') %>
<style>
.home-page { padding: 40px 0 80px; position: relative; z-index: 1; }
.home-header { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
.home-header h1 { font-size: 32px; font-weight: 800; margin-bottom: 6px; }
.home-header p { color: var(--t2); font-size: 14px; }
.prompts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; }
.prompt-card { background: var(--s1); border: 1px solid var(--border); border-radius: var(--rl); padding: 20px; transition: all var(--tr); }
.prompt-card:hover { border-color: var(--border-h); transform: translateY(-3px); }
.prompt-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
.prompt-content { font-size: 13px; color: var(--t2); line-height: 1.7; margin-bottom: 14px; display: -webkit-box; line-clamp: 4; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
.prompt-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 12px; }
.stats { display: flex; gap: 14px; color: var(--t3); font-size: 12px; }
</style>

<div class="page-wrap">
  <div class="container home-page">
    <div class="home-header slide-up">
      <div>
        <h1>My Prompts</h1>
        <p>Manage and review your created prompts.</p>
      </div>
      <a href="/post" class="btn btn-primary">Create Prompt</a>
    </div>

    <% if (!prompts || prompts.length === 0) { %>
      <div class="empty-state">
        <h3>No prompts yet</h3>
        <p>Create your first prompt to get started.</p>
        <a href="/post" class="btn btn-primary" style="margin-top:12px;">Add Prompt</a>
      </div>
    <% } else { %>
      <div class="prompts-grid">
        <% prompts.forEach(function(prompt, idx) { %>
          <div class="prompt-card slide-up">
            <div class="prompt-title"><%= prompt.title %></div>
            <div class="prompt-content"><%= prompt.content %></div>
            <div class="prompt-footer">
              <div class="stats">
                <span>Likes: <%= prompt.likes ? prompt.likes.length : 0 %></span>
                <span>Views: <%= prompt.views || 0 %></span>
              </div>
              <div style="display:flex;gap:8px;">
                <a href="/edit/<%= prompt._id %>" class="btn btn-ghost btn-sm">Edit</a>
                <a href="/post/view/<%= prompt._id %>" class="btn btn-ghost btn-sm">View</a>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<script src="/main.js"></script>
</body></html>
